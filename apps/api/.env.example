# Local default. Set to supabase in Cloud Run.
MARGINALIA_STORAGE_BACKEND=filesystem
MARGINALIA_DATA_DIR=../../data
MARGINALIA_MAX_PDF_BYTES=31457280

# Marginalia Supabase project (the URL and bucket name are not secrets).
SUPABASE_URL=https://srdwuagoecrcahjhwsco.supabase.co
SUPABASE_STORAGE_BUCKET=marginalia-papers
SUPABASE_SECRET_KEY=replace-with-a-new-backend-secret-key

# Exact production origins, comma-separated. Loopback origins remain allowed locally.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://YOUR_VERCEL_DOMAIN
# Optional for Vercel preview URLs; use a narrowly scoped regular expression.
CORS_ALLOW_ORIGIN_REGEX=
