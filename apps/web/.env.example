# Public Cloud Run base URL. NEXT_PUBLIC values are compiled into the browser bundle.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# Vercel cannot reach an Ollama process on a developer laptop.
MARGINALIA_AI_PROVIDER=disabled
MARGINALIA_OLLAMA_URL=http://localhost:11434
MARGINALIA_LOCAL_MODEL=gemma4:12b
